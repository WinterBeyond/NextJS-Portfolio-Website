{
	"compilerOptions": {
		"target": "ES6",
		"module": "ESNext",
		"baseUrl": ".",
		"paths": {
			"@/*": ["./src/*"]
		},
		"forceConsistentCasingInFileNames": true,
		"moduleResolution": "Node",
		"isolatedModules": true,
		"jsx": "preserve",
		"lib": ["dom", "dom.iterable", "esnext"],
		"skipLibCheck": true,
		"noEmit": true,
		"incremental": true,
		"esModuleInterop": true,
		"resolveJsonModule": true,
		"allowJs": true,
		"strict": true
	},
	"exclude": ["node_modules/"],
	"include": ["src/**/*", "tsconfig.json"]
}
